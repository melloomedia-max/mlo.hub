<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title>Media Hub — Melloo Media</title>
  <meta name="description" content="Access your brand media — logos, graphics, and creative assets from Melloo Media.">
  <link rel="icon" type="image/png" href="/img/logo-icon.png">
  <link rel="apple-touch-icon" href="/img/logo-icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --accent: #6366f1;
      --accent-2: #a78bfa;
      --glow: rgba(99,102,241,0.3);
      --green: #10b981;
      --rose: #f43f5e;
      --amber: #f59e0b;
      --teal: #2dd4bf;

      --glass: rgba(255,255,255,0.05);
      --glass-hi: rgba(255,255,255,0.09);
      --border: rgba(255,255,255,0.09);
      --border-hi: rgba(255,255,255,0.18);
      --text: rgba(255,255,255,0.95);
      --muted: rgba(255,255,255,0.50);
      --faint: rgba(255,255,255,0.25);

      --radius: 16px;
      --radius-sm: 10px;
      --ease: cubic-bezier(0.4,0,0.2,1);
      --spring: cubic-bezier(0.34,1.56,0.64,1);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      min-height: 100vh; color: var(--text);
      line-height: 1.5; -webkit-font-smoothing: antialiased;
      background:
        radial-gradient(ellipse 70% 55% at 15% 10%, rgba(255, 59, 59, 0.15) 0%, transparent 60%),
        radial-gradient(ellipse 55% 45% at 85% 80%, rgba(99, 102, 241, 0.10) 0%, transparent 55%),
        radial-gradient(ellipse 45% 35% at 50% 40%, rgba(255, 59, 59, 0.05) 0%, transparent 50%),
        #070711;
      background-attachment: fixed;
    }

    /* ─── Loading ──────────────────────────────────────────── */
    #loading-screen {
      position: fixed; inset: 0; z-index: 9999;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 22px;
      background: #070711;
      transition: opacity 0.6s var(--ease);
    }
    #loading-screen.hide { opacity: 0; pointer-events: none; }

    .ld-logo {
      width: 84px; height: 84px; border-radius: 18px;
      object-fit: cover;
    }

    .ld-text {
      font-family: 'Atkinson Hyperlegible', sans-serif;
      font-size: 26px; font-weight: 700; font-style: italic;
      background: linear-gradient(135deg, #ff3b3b, #cc0000);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }

    .ld-bar-wrap {
      width: 140px; height: 3px;
      background: rgba(255,255,255,0.06);
      border-radius: 99px; overflow: hidden;
    }

    .ld-bar {
      height: 100%; border-radius: 99px;
      background: linear-gradient(90deg, #005eb8, #117aca);
      animation: ldbar 1.2s var(--ease) forwards;
    }

    @keyframes ldbar {
      from { width: 0; } to { width: 100%; }
    }

    /* ─── Error ────────────────────────────────────────────── */
    #error-screen {
      display: none; position: fixed; inset: 0; z-index: 9998;
      flex-direction: column; align-items: center; justify-content: center;
      text-align: center; gap: 16px; padding: 40px;
    }

    /* ─── Shell ────────────────────────────────────────────── */
    .shell {
      position: relative; z-index: 1;
      max-width: 1180px; margin: 0 auto;
      padding: 0 28px 80px;
      opacity: 0; transform: translateY(14px);
      transition: all 0.5s var(--ease);
    }
    .shell.vis { opacity: 1; transform: none; }

    /* ─── Top Bar ──────────────────────────────────────────── */
    .topbar {
      display: flex; align-items: center; justify-content: space-between;
      padding: 28px 0 24px;
      border-bottom: 1px solid var(--border);
    }

    .topbar-brand {
      display: flex; align-items: center; gap: 12px;
    }

    .topbar-logo {
      width: 36px; height: 36px; border-radius: 10px;
      background: linear-gradient(135deg, #ff3b3b, #cc0000);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Atkinson Hyperlegible'; font-size: 15px;
      font-weight: 700; font-style: italic; color: #fff;
      box-shadow: 0 3px 14px rgba(255, 59, 59, 0.3);
    }

    .topbar-name {
      font-family: 'Atkinson Hyperlegible'; font-size: 15px;
      font-weight: 700; font-style: italic; color: var(--text);
    }

    .topbar-tag {
      font-size: 11px; color: var(--muted); font-style: normal; font-weight: 400;
    }

    .topbar-pill {
      display: flex; align-items: center; gap: 5px;
      font-size: 11px; font-weight: 600; color: #6ee7b7;
      background: rgba(16,185,129,0.10);
      border: 1px solid rgba(16,185,129,0.2);
      border-radius: 99px; padding: 6px 14px;
    }

    .topbar-pill::before {
      content: ''; width: 6px; height: 6px;
      background: var(--green); border-radius: 50%;
      box-shadow: 0 0 6px rgba(16,185,129,0.5);
    }

    /* ─── Hero ─────────────────────────────────────────────── */
    .hero {
      padding: 52px 0 4px;
    }

    .hero-eyebrow {
      font-size: 12px; font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--accent-2); margin-bottom: 12px;
    }

    .hero-title {
      font-size: clamp(26px, 4vw, 42px);
      font-weight: 800; letter-spacing: -1.2px; line-height: 1.1;
      background: linear-gradient(135deg, #fff 30%, rgba(255,255,255,0.65) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      margin-bottom: 10px;
    }

    .hero-sub {
      font-size: 14px; color: var(--muted); max-width: 520px; margin-bottom: 4px;
    }

    /* ─── Toolbar ──────────────────────────────────────────── */
    .toolbar {
      display: flex; align-items: center; gap: 12px;
      padding: 20px 0 24px;
      flex-wrap: wrap;
    }

    .search-box {
      flex: 1; min-width: 180px; max-width: 380px;
      position: relative;
    }

    .search-box input {
      width: 100%; padding: 10px 14px 10px 38px;
      background: var(--glass); border: 1px solid var(--border);
      border-radius: 12px; font-size: 13px; font-family: inherit;
      color: var(--text); outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .search-box input:focus {
      border-color: rgba(99,102,241,0.4);
      box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
    }

    .search-box input::placeholder { color: var(--faint); }

    .search-box svg {
      position: absolute; left: 12px; top: 50%;
      transform: translateY(-50%);
      width: 16px; height: 16px;
      fill: none; stroke: var(--faint); stroke-width: 2;
      stroke-linecap: round; stroke-linejoin: round;
    }

    .filter-btn {
      padding: 9px 16px; border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--glass);
      font-size: 12px; font-weight: 600; font-family: inherit;
      color: var(--muted); cursor: pointer;
      transition: all 0.2s var(--ease);
      white-space: nowrap;
    }

    .filter-btn:hover { border-color: var(--border-hi); color: var(--text); }

    .filter-btn.active {
      background: rgba(99,102,241,0.12);
      border-color: rgba(99,102,241,0.3);
      color: #c4b5fd;
    }

    .toolbar-right {
      margin-left: auto;
      display: flex; align-items: center; gap: 8px;
    }

    .view-btn {
      width: 36px; height: 36px; border-radius: 10px;
      border: 1px solid var(--border); background: var(--glass);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; color: var(--muted);
      transition: all 0.2s;
    }

    .view-btn:hover, .view-btn.active {
      border-color: var(--border-hi); color: var(--text);
      background: var(--glass-hi);
    }

    .view-btn svg {
      width: 16px; height: 16px;
      fill: none; stroke: currentColor; stroke-width: 2;
      stroke-linecap: round; stroke-linejoin: round;
    }

    /* ─── Breadcrumb ───────────────────────────────────────── */
    .breadcrumb {
      display: flex; align-items: center; gap: 6px;
      padding: 0 0 20px; font-size: 13px;
    }

    .breadcrumb a {
      color: var(--accent-2); text-decoration: none;
      font-weight: 500; cursor: pointer;
      transition: color 0.2s;
    }

    .breadcrumb a:hover { color: #fff; }

    .breadcrumb .sep { color: var(--faint); font-size: 11px; }

    .breadcrumb .current {
      color: var(--text); font-weight: 600;
    }

    /* ─── Folder Grid ──────────────────────────────────────── */
    .folders-section {
      margin-bottom: 28px;
    }

    .section-label {
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--faint);
      margin-bottom: 12px; padding-left: 2px;
    }

    .folders-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 12px;
    }

    .folder-card {
      display: flex; align-items: center; gap: 12px;
      padding: 16px 18px; border-radius: 14px;
      background: var(--glass);
      border: 1px solid var(--border);
      cursor: pointer; transition: all 0.25s var(--ease);
      text-decoration: none; color: var(--text);
    }

    .folder-card:hover {
      border-color: var(--border-hi);
      transform: translateY(-2px);
      box-shadow: 0 6px 24px rgba(0,0,0,0.3);
      background: var(--glass-hi);
    }

    .folder-card-icon {
      font-size: 26px; flex-shrink: 0;
      filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
    }

    .folder-card-name {
      font-size: 13px; font-weight: 600;
      white-space: nowrap; overflow: hidden;
      text-overflow: ellipsis;
    }

    .folder-card-arrow {
      margin-left: auto; color: var(--faint);
      font-size: 14px; flex-shrink: 0;
      transition: transform 0.2s;
    }

    .folder-card:hover .folder-card-arrow { transform: translateX(3px); }

    /* ─── Media Grid ───────────────────────────────────────── */
    .media-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 16px;
    }

    .media-grid.list-view {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .media-card {
      background: var(--glass);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      cursor: pointer;
      transition: all 0.25s var(--ease);
      position: relative;
    }

    .media-card:hover {
      border-color: var(--border-hi);
      transform: translateY(-3px);
      box-shadow: 0 12px 36px rgba(0,0,0,0.4);
    }

    .media-card-thumb {
      width: 100%; height: 165px;
      background: rgba(255,255,255,0.03);
      display: flex; align-items: center; justify-content: center;
      overflow: hidden; position: relative;
    }

    .media-card-thumb img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform 0.4s var(--ease);
    }

    .media-card:hover .media-card-thumb img {
      transform: scale(1.05);
    }

    .media-card-thumb .icon-placeholder {
      font-size: 40px;
      filter: drop-shadow(0 4px 8px rgba(0,0,0,0.4));
    }

    .media-card-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 55%);
      opacity: 0;
      display: flex; align-items: flex-end; justify-content: flex-end;
      padding: 12px;
      transition: opacity 0.25s;
    }

    .media-card:hover .media-card-overlay { opacity: 1; }

    .overlay-btn {
      width: 34px; height: 34px; border-radius: 9px;
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.25);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; color: white;
      transition: all 0.2s;
      margin-left: 6px;
    }

    .overlay-btn:hover {
      background: rgba(255,255,255,0.3);
      transform: scale(1.08);
    }

    .overlay-btn svg {
      width: 16px; height: 16px;
      fill: none; stroke: currentColor; stroke-width: 2;
      stroke-linecap: round; stroke-linejoin: round;
    }

    .media-card-body {
      padding: 14px 16px 16px;
    }

    .media-card-name {
      font-size: 13px; font-weight: 600; color: var(--text);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      margin-bottom: 4px;
    }

    .media-card-meta {
      display: flex; align-items: center; gap: 8px;
      font-size: 11px; color: var(--faint);
    }

    .media-card-type {
      padding: 2px 7px; border-radius: 5px;
      background: rgba(255,255,255,0.06);
      font-weight: 600; font-size: 10px;
      text-transform: uppercase; letter-spacing: 0.04em;
    }

    /* ── List view variant ──── */
    .media-grid.list-view .media-card {
      display: flex; align-items: center;
      border-radius: 12px;
    }

    .media-grid.list-view .media-card-thumb {
      width: 56px; height: 56px; flex-shrink: 0;
      border-radius: 10px; margin: 8px;
    }

    .media-grid.list-view .media-card-body {
      flex: 1; padding: 10px 14px; min-width: 0;
    }

    .media-grid.list-view .media-card-overlay { display: none; }

    .media-grid.list-view .media-card-list-actions {
      display: flex; align-items: center; gap: 6px;
      padding: 0 14px; flex-shrink: 0;
    }

    /* ─── Lightbox ─────────────────────────────────────────── */
    .lightbox {
      position: fixed; inset: 0; z-index: 9000;
      background: rgba(0,0,0,0.92);
      backdrop-filter: blur(24px);
      display: none; align-items: center; justify-content: center;
      flex-direction: column; padding: 30px;
      opacity: 0; transition: opacity 0.3s;
    }

    .lightbox.open { display: flex; opacity: 1; }

    .lightbox-close {
      position: absolute; top: 20px; right: 24px;
      width: 40px; height: 40px; border-radius: 12px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; color: var(--muted);
      font-size: 20px; transition: all 0.2s;
      z-index: 10;
    }

    .lightbox-close:hover { color: white; background: rgba(255,255,255,0.15); }

    .lb-preview {
      max-width: 90vw; max-height: 72vh;
      display: flex; align-items: center; justify-content: center;
    }

    .lightbox-img {
      max-width: 90vw; max-height: 72vh;
      border-radius: 12px; box-shadow: 0 20px 60px rgba(0,0,0,0.6);
      object-fit: contain;
    }

    .lb-video {
      max-width: 90vw; max-height: 72vh;
      border-radius: 12px; box-shadow: 0 20px 60px rgba(0,0,0,0.6);
      background: #000;
    }

    .lb-pdf {
      width: 80vw; height: 72vh;
      border-radius: 12px; border: none;
      box-shadow: 0 20px 60px rgba(0,0,0,0.6);
    }

    .lb-non-preview {
      display: flex; flex-direction: column; align-items: center;
      justify-content: center; gap: 12px; padding: 60px;
    }

    .lb-non-preview .lb-big-icon {
      font-size: 72px;
      filter: drop-shadow(0 8px 16px rgba(0,0,0,0.4));
    }

    .lb-non-preview .lb-type-label {
      font-size: 14px; font-weight: 700; color: var(--muted);
      text-transform: uppercase; letter-spacing: 0.1em;
    }

    .lightbox-info {
      margin-top: 20px; text-align: center;
    }

    .lightbox-name {
      font-size: 16px; font-weight: 700; color: var(--text);
      margin-bottom: 6px;
    }

    .lightbox-size {
      font-size: 12px; color: var(--faint); margin-bottom: 12px;
    }

    .lightbox-actions {
      display: flex; align-items: center; gap: 10px;
      justify-content: center;
    }

    .lb-btn {
      padding: 10px 22px; border-radius: 10px;
      font-size: 13px; font-weight: 600; font-family: inherit;
      cursor: pointer; transition: all 0.2s;
      text-decoration: none;
      display: inline-flex; align-items: center; gap: 6px;
    }

    .lb-btn-primary {
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      border: none; color: white;
      box-shadow: 0 4px 16px var(--glow);
    }

    .lb-btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 22px var(--glow); }

    .lb-btn-secondary {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      color: var(--text);
    }

    .lb-btn-secondary:hover { background: rgba(255,255,255,0.14); }

    /* ─── Request Panel ────────────────────────────────────── */
    .request-section {
      margin-top: 48px;
      background: var(--glass);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      backdrop-filter: blur(20px);
      overflow: hidden;
    }

    .request-head {
      display: flex; align-items: center; gap: 10px;
      padding: 20px 24px 16px;
      border-bottom: 1px solid var(--border);
    }

    .request-head-icon {
      width: 32px; height: 32px; border-radius: 9px;
      background: rgba(45,212,191,0.12);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
    }

    .request-head-text {
      font-size: 14px; font-weight: 700; color: var(--text);
    }

    .request-head-sub {
      font-size: 12px; color: var(--muted); font-weight: 400;
    }

    .request-body { padding: 20px 24px 24px; }

    .request-subject-row {
      display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap;
    }

    .req-chip {
      padding: 6px 14px; border-radius: 99px;
      border: 1px solid var(--border);
      background: var(--glass);
      font-size: 12px; font-weight: 600; font-family: inherit;
      color: var(--muted); cursor: pointer;
      transition: all 0.18s;
    }

    .req-chip:hover { border-color: var(--border-hi); color: var(--text); }
    .req-chip.active {
      background: rgba(99,102,241,0.18);
      border-color: rgba(99,102,241,0.5);
      color: #a5b4fc;
    }

    .request-ta {
      width: 100%; min-height: 100px; resize: none;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
      border-radius: 12px; padding: 14px 16px;
      font-size: 13px; font-family: inherit;
      color: var(--text); outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      margin-bottom: 14px;
    }

    .request-ta::placeholder { color: var(--faint); }

    .request-ta:focus {
      border-color: rgba(99,102,241,0.4);
      box-shadow: 0 0 0 3px rgba(99,102,241,0.08);
    }

    .request-btn {
      padding: 12px 28px;
      background: linear-gradient(135deg, #ff3b3b, #cc0000);
      border: none; border-radius: 12px;
      font-size: 14px; font-weight: 700; font-family: inherit;
      color: white; cursor: pointer;
      box-shadow: 0 4px 16px rgba(255, 59, 59, 0.3);
      transition: all 0.25s var(--spring);
    }

    .request-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 24px var(--glow); }
    .request-btn:active { transform: translateY(0); }
    .request-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    /* ─── Empty ────────────────────────────────────────────── */
    .empty-hub {
      text-align: center; padding: 80px 20px;
    }

    .empty-hub-icon { font-size: 52px; margin-bottom: 16px; }

    .empty-hub-title {
      font-size: 18px; font-weight: 700; margin-bottom: 8px;
    }

    .empty-hub-sub {
      font-size: 13px; color: var(--muted); max-width: 360px; margin: 0 auto;
    }

    /* ─── Stats bar ────────────────────────────────────────── */
    .stats-bar {
      display: flex; align-items: center; gap: 20px;
      padding: 0 0 4px; font-size: 12px; color: var(--faint);
    }

    .stats-bar strong { color: var(--muted); font-weight: 600; }

    /* ─── Footer ───────────────────────────────────────────── */
    .footer {
      text-align: center; padding: 48px 0 16px;
      border-top: 1px solid var(--border);
      margin-top: 48px; font-size: 12px; color: var(--faint);
    }

    .footer a {
      color: var(--accent-2); text-decoration: none;
      transition: color 0.2s;
    }

    .footer a:hover { color: white; }

    /* ─── Toast ────────────────────────────────────────────── */
    .toast {
      position: fixed; bottom: 28px; left: 50%;
      transform: translateX(-50%) translateY(10px);
      background: rgba(18,18,32,0.95);
      border: 1px solid var(--border-hi);
      border-radius: 12px; padding: 12px 20px;
      font-size: 13px; font-weight: 600; color: var(--text);
      box-shadow: 0 8px 28px rgba(0,0,0,0.5);
      backdrop-filter: blur(16px);
      opacity: 0; transition: all 0.3s var(--spring);
      z-index: 9500; white-space: nowrap;
    }

    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    /* ─── Animations ───────────────────────────────────────── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .anim { animation: fadeUp 0.45s var(--ease) both; }

    /* ─── Responsive ───────────────────────────────────────── */
    @media (max-width: 640px) {
      .shell { padding: 0 16px 60px; }
      .hero { padding: 36px 0 4px; }
      .media-grid { grid-template-columns: repeat(auto-fill, minmax(155px, 1fr)); gap: 10px; }
      .media-card-thumb { height: 120px; }
      .folders-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); }
      .toolbar { gap: 8px; }
      .search-box { min-width: 140px; }
    }
  </style>
</head>
<body>



  <!-- Loading -->
  <div id="loading-screen">
    <img src="/img/logo-icon.png" class="ld-logo" onerror="this.style.display='none'">
    <div class="ld-text">melloo media</div>
    <div class="ld-bar-wrap"><div class="ld-bar"></div></div>
  </div>

  <!-- Error -->
  <div id="error-screen">
    <div style="font-size:52px;">🔗</div>
    <h2 style="font-size:20px;font-weight:700;">Invalid Portal Link</h2>
    <p style="color:var(--muted);font-size:14px;max-width:340px;">
      This link may be expired or incorrect. Please contact your Melloo Media account manager.
    </p>
    <a href="mailto:melloomedia@gmail.com"
       style="margin-top:20px;display:inline-flex;align-items:center;gap:8px;
              background:linear-gradient(135deg,var(--accent),var(--accent-2));
              color:white;padding:11px 22px;border-radius:12px;
              font-size:14px;font-weight:600;text-decoration:none;">
      📧 Contact Us
    </a>
  </div>

  <!-- Main Shell -->
  <div class="shell" id="shell">

    <!-- Top bar -->
    <div class="topbar anim" style="animation-delay:0.05s;">
      <div class="topbar-brand">
        <div class="topbar-logo">m</div>
        <div>
          <div class="topbar-name">melloo media</div>
          <div class="topbar-tag">Creative Media Hub</div>
        </div>
      </div>
      <div style="display:flex; align-items:center; gap:16px;">
        <div class="topbar-pill">Portal Active</div>
        <a href="/logout" style="color:rgba(255,255,255,0.4); text-decoration:none; font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; transition:0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.4)'">Logout</a>
      </div>
    </div>

    <!-- Hero -->
    <div class="hero anim" style="animation-delay:0.1s;">
      <div class="hero-eyebrow" id="hero-eyebrow">Your Brand Media</div>
      <h1 class="hero-title" id="hero-title">Media Hub</h1>
      <p class="hero-sub" id="hero-sub">Browse, preview, and download all your brand assets delivered by Melloo Media.</p>
    </div>

    <!-- Toolbar -->
    <div class="toolbar anim" style="animation-delay:0.15s;">
      <div class="search-box">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input type="text" id="search-input" placeholder="Search files...">
      </div>
      <button class="filter-btn active" data-filter="all" onclick="setFilter('all')">All</button>
      <button class="filter-btn" data-filter="image" onclick="setFilter('image')">🖼️ Images</button>
      <button class="filter-btn" data-filter="video" onclick="setFilter('video')">🎬 Video</button>
      <button class="filter-btn" data-filter="pdf" onclick="setFilter('pdf')">📕 PDF</button>
      <button class="filter-btn" data-filter="other" onclick="setFilter('other')">📄 Other</button>
      <div class="toolbar-right">
        <button class="view-btn active" id="view-grid" onclick="setView('grid')" title="Grid view">
          <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        </button>
        <button class="view-btn" id="view-list" onclick="setView('list')" title="List view">
          <svg viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        </button>
      </div>
    </div>

    <!-- Breadcrumb -->
    <div class="breadcrumb anim" id="breadcrumb" style="animation-delay:0.18s; display: none;"></div>

    <!-- Stats -->
    <div class="stats-bar anim" id="stats-bar" style="animation-delay:0.18s;"></div>

    <!-- Folders -->
    <div class="folders-section anim" id="folders-section" style="animation-delay:0.2s; display: none;">
      <div class="section-label">📁 Folders</div>
      <div class="folders-grid" id="folders-grid"></div>
    </div>

    <!-- Media Files -->
    <div id="media-area" class="anim" style="animation-delay:0.25s;">
      <div class="media-grid" id="media-grid"></div>
    </div>

    <!-- Request -->
    <div class="request-section anim" style="animation-delay:0.3s;">
      <div class="request-head">
        <div class="request-head-icon">💬</div>
        <div>
          <div class="request-head-text">Send a Request</div>
          <div class="request-head-sub">Revision, question, or new deliverable — we'll get back to you.</div>
        </div>
      </div>
      <div class="request-body">
        <div class="request-subject-row" id="subject-chips">
          <button class="req-chip active" data-subject="Revision">✏️ Revision</button>
          <button class="req-chip" data-subject="New Export">📦 New Export</button>
          <button class="req-chip" data-subject="Question">❓ Question</button>
          <button class="req-chip" data-subject="Access Issue">🔑 Access Issue</button>
          <button class="req-chip" data-subject="Other">💬 Other</button>
        </div>
        <textarea class="request-ta" id="request-message"
          placeholder="Describe what you need — new file formats, color variations, updated logos, additional sizes..."></textarea>
        <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
          <button class="request-btn" id="request-btn" onclick="sendRequest()">
            📨 Send to Melloo Media
          </button>
          <span id="request-status" style="font-size:12px; color:var(--muted); display:none;"></span>
        </div>
      </div>
    </div>

    <!-- Request History -->
    <div class="request-section anim" style="animation-delay:0.35s; margin-top:16px;" id="request-history-section">
      <div class="request-head">
        <div class="request-head-icon">📋</div>
        <div>
          <div class="request-head-text">Your Requests</div>
          <div class="request-head-sub">Track the status of everything you've sent us.</div>
        </div>
      </div>
      <div id="request-history-list" style="padding:0 24px 20px;">
        <div style="text-align:center;padding:24px;color:var(--faint);font-size:13px;">Loading...</div>
      </div>
    </div>

    <footer class="footer anim" style="animation-delay:0.35s;">
      <p>Powered by <strong style="color:var(--text);">Melloo Media</strong> · <a href="mailto:melloomedia@gmail.com">melloomedia@gmail.com</a></p>
      <p style="margin-top:4px;">This portal link is private — do not share it publicly.</p>
    </footer>
  </div>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox">
    <div class="lightbox-close" onclick="closeLightbox()">✕</div>
    <div class="lb-preview" id="lb-preview"></div>
    <div class="lightbox-info">
      <div class="lightbox-name" id="lb-name"></div>
      <div class="lightbox-size" id="lb-size"></div>
      <div class="lightbox-actions" id="lb-actions"></div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script>
    // ─── State ──────────────────────────────────────────────
    const pathParts = window.location.pathname.split('/').filter(Boolean);
    const token = pathParts[pathParts.length - 1];

    let allFiles = [];
    let allFolders = [];
    let currentFilter = 'all';
    let currentView = 'grid';
    let rootFolderId = null;

    // Proxy helpers — stream content through our server
    function proxyUrl(fileId)   { return `/portal/api/${token}/file/${fileId}`; }
    function downloadUrl(fileId) { return `/portal/api/${token}/download/${fileId}`; }
    function isProxyable(mime) {
      return mime && !mime.includes('google-apps');
    }
    let folderStack = []; // {id, name}

    // ─── Toast ──────────────────────────────────────────────
    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 3000);
    }

    // ─── Helpers ────────────────────────────────────────────
    function mimeCategory(mime) {
      if (!mime) return 'other';
      if (mime.includes('image')) return 'image';
      if (mime.includes('video')) return 'video';
      if (mime.includes('pdf'))   return 'pdf';
      return 'other';
    }

    function mimeIcon(mime) {
      if (!mime) return '📄';
      if (mime.includes('image'))  return '🖼️';
      if (mime.includes('pdf'))    return '📕';
      if (mime.includes('video'))  return '🎬';
      if (mime.includes('audio'))  return '🎵';
      if (mime.includes('zip') || mime.includes('archive'))  return '📦';
      if (mime.includes('spreadsheet') || mime.includes('excel')) return '📊';
      if (mime.includes('presentation')) return '📽️';
      if (mime.includes('document') || mime.includes('word'))    return '📝';
      if (mime.includes('font'))   return '🔡';
      if (mime.includes('svg'))    return '🎨';
      return '📄';
    }

    function mimeLabel(mime) {
      if (!mime) return 'FILE';
      if (mime.includes('png'))  return 'PNG';
      if (mime.includes('jpeg') || mime.includes('jpg')) return 'JPG';
      if (mime.includes('svg'))  return 'SVG';
      if (mime.includes('gif'))  return 'GIF';
      if (mime.includes('webp')) return 'WEBP';
      if (mime.includes('pdf'))  return 'PDF';
      if (mime.includes('mp4'))  return 'MP4';
      if (mime.includes('mov'))  return 'MOV';
      if (mime.includes('avi'))  return 'AVI';
      if (mime.includes('mp3'))  return 'MP3';
      if (mime.includes('wav'))  return 'WAV';
      if (mime.includes('zip'))  return 'ZIP';
      if (mime.includes('google-apps.document'))     return 'GDOC';
      if (mime.includes('google-apps.spreadsheet'))  return 'GSHEET';
      if (mime.includes('google-apps.presentation')) return 'GSLIDE';
      return mime.split('/').pop().toUpperCase().slice(0,6);
    }

    function formatSize(bytes) {
      if (!bytes) return '';
      const mb = bytes / (1024 * 1024);
      if (mb >= 1) return mb.toFixed(1) + ' MB';
      return (bytes / 1024).toFixed(0) + ' KB';
    }

    function formatDate(d) {
      if (!d) return '';
      return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    }

    // ─── Filtering ──────────────────────────────────────────
    function setFilter(f) {
      currentFilter = f;
      document.querySelectorAll('.filter-btn').forEach(b => {
        b.classList.toggle('active', b.dataset.filter === f);
      });
      renderMedia();
    }

    function setView(v) {
      currentView = v;
      document.getElementById('view-grid').classList.toggle('active', v === 'grid');
      document.getElementById('view-list').classList.toggle('active', v === 'list');
      renderMedia();
    }

    function getFilteredFiles() {
      const q = document.getElementById('search-input').value.toLowerCase().trim();
      return allFiles.filter(f => {
        if (currentFilter !== 'all' && mimeCategory(f.mimeType) !== currentFilter) return false;
        if (q && !f.name.toLowerCase().includes(q)) return false;
        return true;
      });
    }

    // ─── Render Folders ─────────────────────────────────────
    function renderFolders() {
      const section = document.getElementById('folders-section');
      const grid = document.getElementById('folders-grid');

      if (!allFolders.length) {
        section.style.display = 'none';
        return;
      }

      section.style.display = 'block';
      grid.innerHTML = allFolders.map(f => `
        <div class="folder-card" onclick="openFolder('${f.id}', '${f.name.replace(/'/g, "\\'")}')">
          <span class="folder-card-icon">📁</span>
          <span class="folder-card-name">${f.name}</span>
          <span class="folder-card-arrow">→</span>
        </div>
      `).join('');
    }

    // ─── Render Media Grid ──────────────────────────────────
    function renderMedia() {
      const grid = document.getElementById('media-grid');
      const files = getFilteredFiles();

      // stats
      const statsBar = document.getElementById('stats-bar');
      const totalSize = allFiles.reduce((a, f) => a + (parseInt(f.size) || 0), 0);
      statsBar.innerHTML = `
        <span><strong>${allFiles.length}</strong> files</span>
        <span><strong>${allFolders.length}</strong> folders</span>
        ${totalSize ? `<span><strong>${formatSize(totalSize)}</strong> total</span>` : ''}
      `;

      grid.className = 'media-grid' + (currentView === 'list' ? ' list-view' : '');

      if (!files.length) {
        grid.innerHTML = `
          <div class="empty-hub" style="grid-column: 1/-1;">
            <div class="empty-hub-icon">${currentFilter !== 'all' ? '🔍' : '📂'}</div>
            <div class="empty-hub-title">${currentFilter !== 'all' ? 'No matching files' : 'No files here yet'}</div>
            <div class="empty-hub-sub">${currentFilter !== 'all' ? 'Try a different filter or search term.' : 'Your creative assets will appear here once delivered by Melloo.'}</div>
          </div>`;
        return;
      }

      if (currentView === 'grid') {
        grid.innerHTML = files.map((f, i) => {
          const isImg = mimeCategory(f.mimeType) === 'image';
          const canProxy = isProxyable(f.mimeType);
          const thumbSrc = isImg && canProxy ? proxyUrl(f.id) : (f.thumbnailLink || '');
          const hasThumb = isImg && (canProxy || f.thumbnailLink);
          const icon = mimeIcon(f.mimeType);
          const typeLabel = mimeLabel(f.mimeType);
          const sizeStr = formatSize(f.size);
          const dlUrl = canProxy ? downloadUrl(f.id) : (f.webContentLink || '');

          return `
            <div class="media-card" onclick="openPreview(${i})" style="animation: fadeUp 0.4s ${0.05 * i}s var(--ease) both;">
              <div class="media-card-thumb">
                ${hasThumb
                  ? `<img src="${thumbSrc}" alt="${f.name}" loading="lazy">`
                  : `<span class="icon-placeholder">${icon}</span>`}
                <div class="media-card-overlay">
                  ${dlUrl ? `
                  <a class="overlay-btn" href="${dlUrl}" onclick="event.stopPropagation()" download title="Download">
                    <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                  </a>` : ''}
                  <div class="overlay-btn" onclick="event.stopPropagation(); window.open('${f.webViewLink}','_blank')" title="Open in Drive">
                    <svg viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  </div>
                </div>
              </div>
              <div class="media-card-body">
                <div class="media-card-name" title="${f.name}">${f.name}</div>
                <div class="media-card-meta">
                  <span class="media-card-type">${typeLabel}</span>
                  ${sizeStr ? `<span>${sizeStr}</span>` : ''}
                </div>
              </div>
            </div>
          `;
        }).join('');
      } else {
        grid.innerHTML = files.map((f, i) => {
          const isImg = mimeCategory(f.mimeType) === 'image';
          const canProxy = isProxyable(f.mimeType);
          const thumbSrc = isImg && canProxy ? proxyUrl(f.id) : (f.thumbnailLink || '');
          const hasThumb = isImg && (canProxy || f.thumbnailLink);
          const icon = mimeIcon(f.mimeType);
          const typeLabel = mimeLabel(f.mimeType);
          const sizeStr = formatSize(f.size);
          const dlUrl = canProxy ? downloadUrl(f.id) : (f.webContentLink || '');

          return `
            <div class="media-card" onclick="openPreview(${i})" style="animation: fadeUp 0.3s ${0.03 * i}s var(--ease) both;">
              <div class="media-card-thumb">
                ${hasThumb
                  ? `<img src="${thumbSrc}" alt="${f.name}" loading="lazy">`
                  : `<span class="icon-placeholder" style="font-size:24px;">${icon}</span>`}
              </div>
              <div class="media-card-body">
                <div class="media-card-name" title="${f.name}">${f.name}</div>
                <div class="media-card-meta">
                  <span class="media-card-type">${typeLabel}</span>
                  ${sizeStr ? `<span>${sizeStr}</span>` : ''}
                  <span>${formatDate(f.modifiedTime)}</span>
                </div>
              </div>
              <div class="media-card-list-actions">
                ${dlUrl ? `
                <a class="overlay-btn" style="background:rgba(255,255,255,0.06);border-color:var(--border);text-decoration:none;"
                     href="${dlUrl}" onclick="event.stopPropagation()" download title="Download">
                  <svg viewBox="0 0 24 24" style="width:14px;height:14px;"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                </a>` : ''}
                <div class="overlay-btn" style="background:rgba(255,255,255,0.06);border-color:var(--border);"
                     onclick="event.stopPropagation(); window.open('${f.webViewLink}','_blank')" title="Open in Drive">
                  <svg viewBox="0 0 24 24" style="width:14px;height:14px;"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </div>
              </div>
            </div>`;
        }).join('');
      }
    }

    // ─── Breadcrumb ─────────────────────────────────────────
    function renderBreadcrumb() {
      const el = document.getElementById('breadcrumb');
      if (!folderStack.length) { el.style.display = 'none'; return; }

      el.style.display = 'flex';
      let html = `<a onclick="goToRoot()">🏠 Home</a>`;
      folderStack.forEach((f, i) => {
        html += `<span class="sep">›</span>`;
        if (i < folderStack.length - 1) {
          html += `<a onclick="goToFolder(${i})">${f.name}</a>`;
        } else {
          html += `<span class="current">${f.name}</span>`;
        }
      });
      el.innerHTML = html;
    }

    // ─── Navigation ─────────────────────────────────────────
    async function openFolder(folderId, folderName) {
      try {
        const res = await fetch(`/portal/api/${token}/folder/${folderId}`);
        if (!res.ok) throw new Error('Failed');
        const data = await res.json();

        folderStack.push({ id: folderId, name: data.folderName || folderName });
        allFiles = data.files || [];
        allFolders = data.folders || [];

        renderBreadcrumb();
        renderFolders();
        renderMedia();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } catch (e) {
        showToast('❌ Could not open folder');
      }
    }

    function goToRoot() {
      folderStack = [];
      loadPortalData();
    }

    function goToFolder(index) {
      const target = folderStack[index];
      folderStack = folderStack.slice(0, index);
      openFolder(target.id, target.name);
      folderStack.pop(); // openFolder will push it back
    }

    // ─── Lightbox ───────────────────────────────────────────
    function openPreview(idx) {
      const files = getFilteredFiles();
      const f = files[idx];
      if (!f) return;

      const lb = document.getElementById('lightbox');
      const preview = document.getElementById('lb-preview');
      const nameEl = document.getElementById('lb-name');
      const sizeEl = document.getElementById('lb-size');
      const actions = document.getElementById('lb-actions');

      const cat = mimeCategory(f.mimeType);
      const canProxy = isProxyable(f.mimeType);
      const fileUrl = canProxy ? proxyUrl(f.id) : '';
      const dlUrl = canProxy ? downloadUrl(f.id) : (f.webContentLink || '');

      // Build preview content based on type
      if (cat === 'image' && canProxy) {
        preview.innerHTML = `<img class="lightbox-img" src="${fileUrl}" alt="${f.name}">`;
      } else if (cat === 'video' && canProxy) {
        preview.innerHTML = `<video class="lb-video" controls autoplay><source src="${fileUrl}" type="${f.mimeType}">Your browser does not support video.</video>`;
      } else if (cat === 'pdf' && canProxy) {
        preview.innerHTML = `<iframe class="lb-pdf" src="${fileUrl}" title="${f.name}"></iframe>`;
      } else {
        // Non-previewable: show big icon + type
        preview.innerHTML = `
          <div class="lb-non-preview">
            <div class="lb-big-icon">${mimeIcon(f.mimeType)}</div>
            <div class="lb-type-label">${mimeLabel(f.mimeType)} File</div>
          </div>
        `;
      }

      nameEl.textContent = f.name;
      sizeEl.textContent = [formatSize(f.size), formatDate(f.modifiedTime)].filter(Boolean).join(' · ');

      let actHtml = '';
      if (dlUrl) {
        actHtml += `<a class="lb-btn lb-btn-primary" href="${dlUrl}" download>⬇️ Download</a>`;
      }
      actHtml += `<a class="lb-btn lb-btn-secondary" href="${f.webViewLink}" target="_blank">🔗 Open in Drive</a>`;
      actions.innerHTML = actHtml;

      lb.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      const preview = document.getElementById('lb-preview');
      // Stop any playing video/audio
      const vid = preview.querySelector('video');
      if (vid) vid.pause();
      preview.innerHTML = '';
      document.getElementById('lightbox').classList.remove('open');
      document.body.style.overflow = '';
    }

    document.getElementById('lightbox').addEventListener('click', function(e) {
      if (e.target === this) closeLightbox();
    });

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeLightbox();
    });

    // ─── Search ─────────────────────────────────────────────
    document.getElementById('search-input').addEventListener('input', renderMedia);

    // ─── Load ───────────────────────────────────────────────
    async function loadPortalData() {
      if (!token || token === 'portal') {
        document.getElementById('loading-screen').style.display = 'none';
        document.getElementById('error-screen').style.display = 'flex';
        return;
      }

      try {
        const res = await fetch(`/portal/api/${token}`);
        if (!res.ok) throw new Error('Invalid');
        const data = await res.json();

        // Hero
        const name = data.client.firstName || data.client.name.split(' ')[0] || '';
        const company = data.client.company;
        document.getElementById('hero-eyebrow').textContent =
          company ? company.toUpperCase() : 'YOUR BRAND MEDIA';
        document.getElementById('hero-title').textContent =
          company ? `${company} Media Hub` : (name ? `${name}'s Media Hub` : 'Media Hub');
        document.getElementById('hero-sub').textContent =
          name
            ? `Welcome back, ${name}. Browse, preview, and download your creative assets below.`
            : 'Browse, preview, and download all your brand assets delivered by Melloo Media.';

        rootFolderId = data.rootFolderId;
        allFiles = data.files || [];
        allFolders = data.folders || [];

        renderBreadcrumb();
        renderFolders();
        renderMedia();

        // Reveal
        setTimeout(() => {
          const ls = document.getElementById('loading-screen');
          ls.classList.add('hide');
          setTimeout(() => ls.style.display = 'none', 600);
          document.getElementById('shell').classList.add('vis');
        }, 900);

      } catch (e) {
        document.getElementById('loading-screen').style.display = 'none';
        document.getElementById('error-screen').style.display = 'flex';
      }
    }

    // ─── Subject Chips ──────────────────────────────────────
    let activeSubject = 'Revision';
    document.getElementById('subject-chips').addEventListener('click', e => {
      const chip = e.target.closest('.req-chip');
      if (!chip) return;
      document.querySelectorAll('.req-chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      activeSubject = chip.dataset.subject;
    });

    // ─── Send Request ───────────────────────────────────────
    async function sendRequest() {
      const msg = document.getElementById('request-message').value.trim();
      if (!msg) { showToast('Please describe your request first.'); return; }

      const btn = document.getElementById('request-btn');
      const statusEl = document.getElementById('request-status');
      btn.disabled = true;
      btn.textContent = '⏳ Sending...';
      statusEl.style.display = 'none';

      try {
        const res = await fetch(`/portal/api/${token}/request`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: msg, subject: activeSubject })
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || `Server error ${res.status}`);

        document.getElementById('request-message').value = '';
        statusEl.textContent = `✅ Request #${data.requestId} submitted — we'll be in touch!`;
        statusEl.style.display = 'inline';
        statusEl.style.color = '#34d399';
        showToast(`✅ Request #${data.requestId} sent!`);
        loadRequestHistory();
      } catch (e) {
        console.error('[Portal] Request submit error:', e);
        statusEl.textContent = `❌ ${e.message}`;
        statusEl.style.display = 'inline';
        statusEl.style.color = '#f87171';
        showToast(`❌ ${e.message}`);
      } finally {
        btn.disabled = false;
        btn.textContent = '📨 Send to Melloo Media';
      }
    }

    // ─── Request History ────────────────────────────────────
    const STATUS_LABEL = { new: 'New', in_progress: 'In Progress', completed: '✅ Done', archived: 'Archived' };
    const STATUS_COLOR = { new: '#a78bfa', in_progress: '#fbbf24', completed: '#34d399', archived: '#6b7280' };

    async function loadRequestHistory() {
      const container = document.getElementById('request-history-list');
      try {
        const res = await fetch(`/portal/api/${token}/requests`);
        if (!res.ok) { container.innerHTML = ''; return; }
        const requests = await res.json();
        if (!requests.length) {
          container.innerHTML = '<div style="text-align:center;padding:24px;color:var(--faint);font-size:13px;">No requests yet — use the form above to contact us.</div>';
          return;
        }
        container.innerHTML = requests.map(r => `
          <div style="display:flex;align-items:flex-start;gap:12px;padding:14px 0;border-bottom:1px solid var(--border);">
            <div style="flex:1;min-width:0;">
              <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                <span style="font-size:12px;font-weight:700;color:var(--text);">#${r.id} · ${r.subject}</span>
                <span style="font-size:11px;font-weight:600;color:${STATUS_COLOR[r.status]||'#a5b4fc'};background:${STATUS_COLOR[r.status]||'#a5b4fc'}18;padding:2px 8px;border-radius:99px;">${STATUS_LABEL[r.status]||r.status}</span>
              </div>
              <div style="font-size:13px;color:var(--muted);line-height:1.4;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">${r.message}</div>
              <div style="font-size:11px;color:var(--faint);margin-top:4px;">${new Date(r.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</div>
            </div>
          </div>
        `).join('');
        // Remove border from last item
        const items = container.querySelectorAll('div[style*="border-bottom"]');
        if (items.length) items[items.length-1].style.borderBottom = 'none';
      } catch (e) {
        container.innerHTML = '';
      }
    }

    loadPortalData();
    loadRequestHistory();
  </script>


  </body>
</html>
